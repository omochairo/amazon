{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amazon Product Data",
  "type": "object",
  "properties": {
    "asin": { "type": "string" },
    "title": { "type": "string" },
    "brand": { "type": "string" },
    "category": { "type": "string" },
    "price_jpy": { "type": "integer" },
    "rating": { "type": "number" },
    "review_count": { "type": "integer" },
    "images": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description_raw": { "type": "string" },
    "url_associate": { "type": "string", "format": "uri" },
    "fetched_at": { "type": "string", "format": "date-time" }
  },
  "required": ["asin", "title", "price_jpy", "url_associate", "fetched_at"]
}
